<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.renli.system.mapper.CsEmployeeLifecycleMapper">
    
    <resultMap type="CsEmployeeLifecycle" id="CsEmployeeLifecycleResult">
        <result property="id"    column="id"    />
        <result property="lifecycleName"    column="lifecycle_name"    />
        <result property="idCard"    column="id_card"    />
        <result property="hireDate"    column="hire_date"    />
        <result property="leaveDate"    column="leave_date"    />
        <result property="lifecycleStatus"    column="lifecycle_status"    />
        <result property="createTime"    column="create_time"    />
    </resultMap>

    <sql id="selectCsEmployeeLifecycleVo">
        select id, lifecycle_name, id_card, hire_date, leave_date, lifecycle_status from cs_employee_lifecycle
    </sql>

    <select id="selectCsEmployeeLifecycleList" parameterType="CsEmployeeLifecycle" resultMap="CsEmployeeLifecycleResult">
        <include refid="selectCsEmployeeLifecycleVo"/>
        <where>  
            <if test="lifecycleName != null  and lifecycleName != ''"> and lifecycle_name like concat('%', #{lifecycleName}, '%')</if>
            <if test="idCard != null  and idCard != ''"> and id_card = #{idCard}</if>
            <if test="hireDate != null "> and hire_date = #{hireDate}</if>
            <if test="leaveDate != null "> and leave_date = #{leaveDate}</if>
            <if test="lifecycleStatus != null  and lifecycleStatus != ''"> and lifecycle_status = #{lifecycleStatus}</if>
        </where>
         order by id desc
    </select>
    
    <select id="selectCsEmployeeLifecycleById" parameterType="Long" resultMap="CsEmployeeLifecycleResult">
        <include refid="selectCsEmployeeLifecycleVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertCsEmployeeLifecycle" parameterType="CsEmployeeLifecycle" useGeneratedKeys="true" keyProperty="id">
        insert into cs_employee_lifecycle
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="lifecycleName != null and lifecycleName != ''">lifecycle_name,</if>
            <if test="idCard != null">id_card,</if>
            <if test="hireDate != null">hire_date,</if>
            <if test="leaveDate != null">leave_date,</if>
            <if test="lifecycleStatus != null">lifecycle_status,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="lifecycleName != null and lifecycleName != ''">#{lifecycleName},</if>
            <if test="idCard != null">#{idCard},</if>
            <if test="hireDate != null">#{hireDate},</if>
            <if test="leaveDate != null">#{leaveDate},</if>
            <if test="lifecycleStatus != null">#{lifecycleStatus},</if>
         </trim>
    </insert>

    <update id="updateCsEmployeeLifecycle" parameterType="CsEmployeeLifecycle">
        update cs_employee_lifecycle
        <trim prefix="SET" suffixOverrides=",">
            <if test="lifecycleName != null and lifecycleName != ''">lifecycle_name = #{lifecycleName},</if>
            <if test="idCard != null">id_card = #{idCard},</if>
            <if test="hireDate != null">hire_date = #{hireDate},</if>
            <if test="leaveDate != null">leave_date = #{leaveDate},</if>
            <if test="lifecycleStatus != null">lifecycle_status = #{lifecycleStatus},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteCsEmployeeLifecycleById" parameterType="Long">
        delete from cs_employee_lifecycle where id = #{id}
    </delete>

    <delete id="deleteCsEmployeeLifecycleByIds" parameterType="String">
        delete from cs_employee_lifecycle where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>
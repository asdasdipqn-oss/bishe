<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.renli.system.mapper.CsLeaveYgapplicationMapper">
    
    <resultMap type="CsLeaveYgapplication" id="CsLeaveYgapplicationResult">
        <result property="id"    column="id"    />
        <result property="employee"    column="employee"    />
        <result property="dept"    column="dept"    />
        <result property="leaveType"    column="leave_type"    />
        <result property="startTime"    column="start_time"    />
        <result property="endTime"    column="end_time"    />
        <result property="reason"    column="reason"    />
        <result property="applicationStatus"    column="application_status"    />
    </resultMap>

    <sql id="selectCsLeaveYgapplicationVo">
        select id, employee, dept, leave_type, start_time, end_time, reason, application_status from cs_leave_jlapplication 
    </sql>

    <select id="selectCsLeaveYgapplicationList" parameterType="CsLeaveYgapplication" resultMap="CsLeaveYgapplicationResult">
        <include refid="selectCsLeaveYgapplicationVo"/>
        <where>  
            <if test="employee != null  and employee != ''"> and employee = #{employee}</if>
            <if test="dept != null  and dept != ''"> and dept = #{dept}</if>
            <if test="leaveType != null  and leaveType != ''"> and leave_type = #{leaveType}</if>
            <if test="startTime != null "> and start_time = #{startTime}</if>
            <if test="endTime != null "> and end_time = #{endTime}</if>
            <if test="reason != null  and reason != ''"> and reason = #{reason}</if>
            <if test="applicationStatus != null  and applicationStatus != ''"> and application_status = #{applicationStatus}</if>
        </where>
        order by id desc
    </select>
    
    <select id="selectCsLeaveYgapplicationById" parameterType="Long" resultMap="CsLeaveYgapplicationResult">
        <include refid="selectCsLeaveYgapplicationVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertCsLeaveYgapplication" parameterType="CsLeaveYgapplication" useGeneratedKeys="true" keyProperty="id">
        insert into cs_leave_jlapplication
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="employee != null and employee != ''">employee,</if>
            <if test="dept != null and dept != ''">dept,</if>
            <if test="leaveType != null and leaveType != ''">leave_type,</if>
            <if test="startTime != null">start_time,</if>
            <if test="endTime != null">end_time,</if>
            <if test="reason != null">reason,</if>
            <if test="applicationStatus != null">application_status,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="employee != null and employee != ''">#{employee},</if>
            <if test="dept != null and dept != ''">#{dept},</if>
            <if test="leaveType != null and leaveType != ''">#{leaveType},</if>
            <if test="startTime != null">#{startTime},</if>
            <if test="endTime != null">#{endTime},</if>
            <if test="reason != null">#{reason},</if>
            <if test="applicationStatus != null">#{applicationStatus},</if>
         </trim>
    </insert>

    <update id="updateCsLeaveYgapplication" parameterType="CsLeaveYgapplication">
        update cs_leave_jlapplication
        <trim prefix="SET" suffixOverrides=",">
            <if test="employee != null and employee != ''">employee = #{employee},</if>
            <if test="dept != null and dept != ''">dept = #{dept},</if>
            <if test="leaveType != null and leaveType != ''">leave_type = #{leaveType},</if>
            <if test="startTime != null">start_time = #{startTime},</if>
            <if test="endTime != null">end_time = #{endTime},</if>
            <if test="reason != null">reason = #{reason},</if>
            <if test="applicationStatus != null">application_status = #{applicationStatus},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteCsLeaveYgapplicationById" parameterType="Long">
        delete from cs_leave_jlapplication where id = #{id}
    </delete>

    <delete id="deleteCsLeaveYgapplicationByIds" parameterType="String">
        delete from cs_leave_jlapplication where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>
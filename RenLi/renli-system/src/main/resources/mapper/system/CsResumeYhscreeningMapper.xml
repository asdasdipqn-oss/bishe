<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.renli.system.mapper.CsResumeYhscreeningMapper">
    
    <resultMap type="CsResumeYhscreening" id="CsResumeYhscreeningResult">
        <result property="id"    column="id"    />
        <result property="candidateName"    column="candidate_name"    />
        <result property="applyPosition"    column="apply_position"    />
        <result property="phone"    column="phone"    />
        <result property="email"    column="email"    />
        <result property="resumeFilePath"    column="resume_file_path"    />
        <result property="screeningStatus"    column="screening_status"    />
        <result property="screeningNote"    column="screening_note"    />
    </resultMap>

    <sql id="selectCsResumeYhscreeningVo">
        select id, candidate_name, apply_position, phone, email, resume_file_path, screening_status, screening_note from cs_resume_screening 
    </sql>

    <select id="selectCsResumeYhscreeningList" parameterType="CsResumeYhscreening" resultMap="CsResumeYhscreeningResult">
        <include refid="selectCsResumeYhscreeningVo"/>
        <where>  
            <if test="candidateName != null  and candidateName != ''"> and candidate_name like concat('%', #{candidateName}, '%')</if>
            <if test="applyPosition != null  and applyPosition != ''"> and apply_position = #{applyPosition}</if>
            <if test="phone != null  and phone != ''"> and phone = #{phone}</if>
            <if test="email != null  and email != ''"> and email = #{email}</if>
            <if test="resumeFilePath != null  and resumeFilePath != ''"> and resume_file_path = #{resumeFilePath}</if>
            <if test="screeningStatus != null  and screeningStatus != ''"> and screening_status = #{screeningStatus}</if>
            <if test="screeningNote != null  and screeningNote != ''"> and screening_note = #{screeningNote}</if>
        </where>
        order by id desc
    </select>
    
    <select id="selectCsResumeYhscreeningById" parameterType="Long" resultMap="CsResumeYhscreeningResult">
        <include refid="selectCsResumeYhscreeningVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertCsResumeYhscreening" parameterType="CsResumeYhscreening" useGeneratedKeys="true" keyProperty="id">
        insert into cs_resume_screening
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="candidateName != null and candidateName != ''">candidate_name,</if>
            <if test="applyPosition != null and applyPosition != ''">apply_position,</if>
            <if test="phone != null">phone,</if>
            <if test="email != null">email,</if>
            <if test="resumeFilePath != null">resume_file_path,</if>
            <if test="screeningStatus != null">screening_status,</if>
            <if test="screeningNote != null">screening_note,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="candidateName != null and candidateName != ''">#{candidateName},</if>
            <if test="applyPosition != null and applyPosition != ''">#{applyPosition},</if>
            <if test="phone != null">#{phone},</if>
            <if test="email != null">#{email},</if>
            <if test="resumeFilePath != null">#{resumeFilePath},</if>
            <if test="screeningStatus != null">#{screeningStatus},</if>
            <if test="screeningNote != null">#{screeningNote},</if>
         </trim>
    </insert>

    <update id="updateCsResumeYhscreening" parameterType="CsResumeYhscreening">
        update cs_resume_screening
        <trim prefix="SET" suffixOverrides=",">
            <if test="candidateName != null and candidateName != ''">candidate_name = #{candidateName},</if>
            <if test="applyPosition != null and applyPosition != ''">apply_position = #{applyPosition},</if>
            <if test="phone != null">phone = #{phone},</if>
            <if test="email != null">email = #{email},</if>
            <if test="resumeFilePath != null">resume_file_path = #{resumeFilePath},</if>
            <if test="screeningStatus != null">screening_status = #{screeningStatus},</if>
            <if test="screeningNote != null">screening_note = #{screeningNote},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteCsResumeYhscreeningById" parameterType="Long">
        delete from cs_resume_screening where id = #{id}
    </delete>

    <delete id="deleteCsResumeYhscreeningByIds" parameterType="String">
        delete from cs_resume_screening where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>

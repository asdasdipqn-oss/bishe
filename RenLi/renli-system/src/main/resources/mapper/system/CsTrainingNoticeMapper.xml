<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.renli.system.mapper.CsTrainingNoticeMapper">
    
    <resultMap type="CsTrainingNotice" id="CsTrainingNoticeResult">
        <result property="id"    column="id"    />
        <result property="titleId"    column="title_id"    />
        <result property="title"    column="title"    />
        <result property="content"    column="content"    />
        <result property="publishTime"    column="publish_time"    />
        <result property="trainingTime"    column="training_time"    />
        <result property="location"    column="location"    />
        <result property="targetDept"    column="target_dept"    />
    </resultMap>

    <sql id="selectCsTrainingNoticeVo">
        select id, title_id, title, content, publish_time, training_time, location, target_dept from cs_training_notice 
    </sql>

    <select id="selectCsTrainingNoticeList" parameterType="CsTrainingNotice" resultMap="CsTrainingNoticeResult">
        <include refid="selectCsTrainingNoticeVo"/>
        <where>  
            <if test="titleId != null  and titleId != ''"> and title_id = #{titleId}</if>
            <if test="title != null  and title != ''"> and title = #{title}</if>
            <if test="content != null  and content != ''"> and content = #{content}</if>
            <if test="publishTime != null "> and publish_time = #{publishTime}</if>
            <if test="trainingTime != null "> and training_time = #{trainingTime}</if>
            <if test="location != null  and location != ''"> and location = #{location}</if>
            <if test="targetDept != null  and targetDept != ''"> and target_dept = #{targetDept}</if>
        </where>
        order by id desc
    </select>
    
    <select id="selectCsTrainingNoticeById" parameterType="Long" resultMap="CsTrainingNoticeResult">
        <include refid="selectCsTrainingNoticeVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertCsTrainingNotice" parameterType="CsTrainingNotice" useGeneratedKeys="true" keyProperty="id">
        insert into cs_training_notice
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="titleId != null and titleId != ''">title_id,</if>
            <if test="title != null and title != ''">title,</if>
            <if test="content != null and content != ''">content,</if>
            <if test="publishTime != null">publish_time,</if>
            <if test="trainingTime != null">training_time,</if>
            <if test="location != null">location,</if>
            <if test="targetDept != null">target_dept,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="titleId != null and titleId != ''">#{titleId},</if>
            <if test="title != null and title != ''">#{title},</if>
            <if test="content != null and content != ''">#{content},</if>
            <if test="publishTime != null">#{publishTime},</if>
            <if test="trainingTime != null">#{trainingTime},</if>
            <if test="location != null">#{location},</if>
            <if test="targetDept != null">#{targetDept},</if>
         </trim>
    </insert>

    <update id="updateCsTrainingNotice" parameterType="CsTrainingNotice">
        update cs_training_notice
        <trim prefix="SET" suffixOverrides=",">
            <if test="titleId != null and titleId != ''">title_id = #{titleId},</if>
            <if test="title != null and title != ''">title = #{title},</if>
            <if test="content != null and content != ''">content = #{content},</if>
            <if test="publishTime != null">publish_time = #{publishTime},</if>
            <if test="trainingTime != null">training_time = #{trainingTime},</if>
            <if test="location != null">location = #{location},</if>
            <if test="targetDept != null">target_dept = #{targetDept},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteCsTrainingNoticeById" parameterType="Long">
        delete from cs_training_notice where id = #{id}
    </delete>

    <delete id="deleteCsTrainingNoticeByIds" parameterType="String">
        delete from cs_training_notice where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>
            <if test="dept != null  and dept != ''"> and dept = #{dept}</if>
            <if test="exceptionDate != null "> and exception_date = #{exceptionDate}</if>
            <if test="explanation != null  and explanation != ''"> and explanation = #{explanation}</if>
            <if test="exceptionStatus != null  and exceptionStatus != ''"> and exception_status = #{exceptionStatus}</if>
        </where>
        order by id desc
    </select>
    
    <select id="selectCsAttendanceJlexceptionById" parameterType="Long" resultMap="CsAttendanceJlexceptionResult">
        <include refid="selectCsAttendanceJlexceptionVo"/>
        where id = #{id}
    </select>
        
    <insert id="insertCsAttendanceJlexception" parameterType="CsAttendanceJlexception" useGeneratedKeys="true" keyProperty="id">
        insert into cs_attendance_jlexception
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="employee != null and employee != ''">employee,</if>
            <if test="dept != null and dept != ''">dept,</if>
            <if test="exceptionDate != null">exception_date,</if>
            <if test="explanation != null">explanation,</if>
            <if test="exceptionStatus != null">exception_status,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="employee != null and employee != ''">#{employee},</if>
            <if test="dept != null and dept != ''">#{dept},</if>
            <if test="exceptionDate != null">#{exceptionDate},</if>
            <if test="explanation != null">#{explanation},</if>
            <if test="exceptionStatus != null">#{exceptionStatus},</if>
         </trim>
    </insert>

    <update id="updateCsAttendanceJlexception" parameterType="CsAttendanceJlexception">
        update cs_attendance_jlexception
        <trim prefix="SET" suffixOverrides=",">
            <if test="employee != null and employee != ''">employee = #{employee},</if>
            <if test="dept != null and dept != ''">dept = #{dept},</if>
            <if test="exceptionDate != null">exception_date = #{exceptionDate},</if>
            <if test="explanation != null">explanation = #{explanation},</if>
            <if test="exceptionStatus != null">exception_status = #{exceptionStatus},</if>

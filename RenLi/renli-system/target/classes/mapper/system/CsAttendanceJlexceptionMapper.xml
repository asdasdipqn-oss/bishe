    <delete id="deleteCsAttendanceJlexceptionById" parameterType="Long">
        delete from cs_attendance_jlexception where id = #{id}
    </delete>

    <delete id="deleteCsAttendanceJlexceptionByIds" parameterType="String">
        delete from cs_attendance_jlexception where id in 
        <foreach item="id" collection="array" open="(" separator="," close=")">
